  "item": [
    {
      "name": "API Gateway",
      "item": [
        {
          "name": "Create Student (via Gateway)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "\"Ivan Ivanov\""},
            "url": {"raw": "http://localhost:8081/api/students", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["api", "students"]}
          }
        },
        {
          "name": "Get All Students (via Gateway)",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/api/students", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["api", "students"]}
          }
        },
        {
          "name": "Get Student by ID (via Gateway)",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/api/students/1", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["api", "students", "1"]}
          }
        },
        {
          "name": "Upload File (via Gateway)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "src": []},
                {"key": "studentName", "value": "Ivan Ivanov", "type": "text"}
              ]
            },
            "url": {"raw": "http://localhost:8081/api/files/upload", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["api", "files", "upload"]}
          }
        },
        {
