          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8081/api/analysis/homeworks/1/reports", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["api", "analysis", "homeworks", "1", "reports"]}
          }
        }
